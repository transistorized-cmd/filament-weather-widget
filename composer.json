{
    "name": "transistorizedcmd/filament-weather-widget",
    "description": "A weather widget for Filament admin panels",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Transistorizedcmd\\FilamentWeatherWidget\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Transistorizedcmd\\FilamentWeatherWidget\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.3",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16",
        "guzzlehttp/guzzle": "^7.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Transistorizedcmd\\FilamentWeatherWidget\\WeatherWidgetServiceProvider"
            ]
        }
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    }
}
